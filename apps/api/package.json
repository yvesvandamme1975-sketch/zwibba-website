{
  "name": "@zwibba/api",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run prisma:generate && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "seed:locations": "tsx scripts/seed-location-options.ts",
    "seed:system-listings": "tsx scripts/seed-system-listings.ts",
    "start": "npm run prisma:migrate:deploy && tsx src/main.ts",
    "test": "node ./scripts/run-tests.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.883.0",
    "@aws-sdk/s3-request-presigner": "^3.883.0",
    "@prisma/client": "^6.7.0",
    "@nestjs/common": "^11.0.12",
    "@nestjs/core": "^11.0.12",
    "@nestjs/platform-express": "^11.0.12",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsx": "^4.19.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.12",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "prisma": "^6.7.0",
    "supertest": "^7.0.0",
    "typescript": "^5.7.3"
  }
}
