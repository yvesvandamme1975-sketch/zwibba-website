generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  boostPurchases     BoostPurchase[]
  chatThreadsAsBuyer ChatThread[]       @relation("BuyerThreads")
  id                 String             @id @default(cuid())
  phoneNumber        String             @unique
  createdAt          DateTime           @default(now())
  sessions           Session[]
  updatedAt          DateTime           @updatedAt
  walletTransactions WalletTransaction[]
}

model Draft {
  id               String      @id @default(cuid())
  area             String
  categoryId       String
  condition        String      @default("")
  createdAt        DateTime    @default(now())
  description      String
  listing          Listing?
  ownerPhoneNumber String
  photos           DraftPhoto[]
  priceCdf         Int
  syncStatus       String      @default("synced")
  title            String
  updatedAt        DateTime    @updatedAt

  @@index([ownerPhoneNumber])
}

model DraftPhoto {
  id             String   @id
  createdAt      DateTime @default(now())
  draft          Draft    @relation(fields: [draftId], references: [id], onDelete: Cascade)
  draftId        String
  objectKey      String
  publicUrl      String
  sourcePresetId String
  updatedAt      DateTime @updatedAt
  uploadStatus   String

  @@index([draftId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
}

model Listing {
  id                 String              @id @default(cuid())
  area               String
  boostPurchases     BoostPurchase[]
  categoryId         String
  chatThreads        ChatThread[]
  createdAt          DateTime            @default(now())
  description        String
  draft              Draft               @relation(fields: [draftId], references: [id], onDelete: Cascade)
  draftId            String              @unique
  moderationDecision ModerationDecision?
  moderationStatus   String
  ownerPhoneNumber   String
  priceCdf           Int
  publishedAt        DateTime?
  slug               String              @unique
  title              String
  updatedAt          DateTime            @updatedAt

  @@index([moderationStatus])
  @@index([ownerPhoneNumber])
}

model ChatThread {
  id               String        @id @default(cuid())
  buyer            User          @relation("BuyerThreads", fields: [buyerUserId], references: [id], onDelete: Cascade)
  buyerLastReadAt  DateTime?
  buyerUserId      String
  createdAt        DateTime      @default(now())
  listing          Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId        String
  messages         ChatMessage[]
  sellerLastReadAt DateTime?
  sellerPhoneNumber String
  updatedAt        DateTime      @updatedAt

  @@index([buyerUserId])
  @@index([listingId])
  @@index([sellerPhoneNumber])
}

model ChatMessage {
  id          String     @id @default(cuid())
  body        String
  createdAt   DateTime   @default(now())
  senderRole  String
  sentAtLabel String
  thread      ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId    String

  @@index([threadId])
}

model ModerationDecision {
  id            String   @id @default(cuid())
  actorLabel    String
  createdAt     DateTime @default(now())
  listing       Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId     String   @unique
  reasonSummary String
  status        String
  updatedAt     DateTime @updatedAt

  @@index([status])
}

model WalletTransaction {
  id             String   @id @default(cuid())
  amountCdf      Int
  createdAt      DateTime @default(now())
  createdAtLabel String
  kind           String
  label          String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String

  @@index([userId, createdAt])
}

model BoostPurchase {
  id                  String   @id @default(cuid())
  amountCdf           Int
  createdAt           DateTime @default(now())
  durationHours       Int
  listing             Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId           String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String
  walletTransactionId String

  @@index([listingId])
  @@index([userId, createdAt])
}

model VerificationAttempt {
  id          String   @id @default(cuid())
  challengeId String
  createdAt   DateTime @default(now())
  phoneNumber String
  status      String
  updatedAt   DateTime @updatedAt

  @@index([phoneNumber, status])
}
